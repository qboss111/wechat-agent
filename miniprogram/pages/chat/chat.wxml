<view class="page">
  <!-- 顶部工具栏 -->
  <view class="topbar">
    <view class="kb-switch">
      <text class="kb-label">知识库</text>
      <switch checked="{{useKnowledge}}" bindchange="onToggleKnowledge" color="#4a6cf7" />
    </view>
    <text class="clear-btn" bindtap="onClear">清空</text>
  </view>

  <!-- 消息列表 -->
  <scroll-view
    class="msg-list"
    scroll-y
    scroll-into-view="{{scrollToView}}"
    scroll-with-animation
  >
    <view
      wx:for="{{messages}}"
      wx:key="index"
      id="msg-{{index}}"
      class="msg-row {{item.role === 'user' ? 'msg-right' : 'msg-left'}}"
    >
      <!-- AI 头像 -->
      <view wx:if="{{item.role === 'assistant'}}" class="avatar">AI</view>

      <view class="bubble-wrap">
        <!-- AI 气泡：用 Markdown 组件渲染；思考中显示加载动效 -->
        <view wx:if="{{item.role === 'assistant'}}" class="bubble bubble-ai">
          <view wx:if="{{item.pending && !item.content}}" class="thinking">
            <view class="dot"></view><view class="dot"></view><view class="dot"></view>
          </view>
          <md wx:else content="{{item.content}}" />
        </view>
        <!-- 用户气泡：纯文本 -->
        <view wx:else class="bubble bubble-user">
          <text class="bubble-text">{{item.content}}</text>
        </view>
        <!-- 知识来源 -->
        <view wx:if="{{item.sources && item.sources.length}}" class="sources">
          <text class="sources-title">📚 知识来源：</text>
          <text
            wx:for="{{item.sources}}"
            wx:for-item="src"
            wx:key="index"
            class="source-tag"
          >{{src.docName}}</text>
        </view>
      </view>

      <!-- 用户头像 -->
      <view wx:if="{{item.role === 'user'}}" class="avatar">我</view>
    </view>
  </scroll-view>

  <!-- 输入区 -->
  <view class="input-bar">
    <input
      class="input"
      value="{{input}}"
      bindinput="onInput"
      placeholder="输入你的问题..."
      confirm-type="send"
      bindconfirm="onSend"
      adjust-position="{{true}}"
    />
    <view class="send-btn {{(!input || sending) ? 'send-disabled' : ''}}" bindtap="onSend">
      发送
    </view>
  </view>
</view>
