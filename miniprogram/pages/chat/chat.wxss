.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg);
}

/* 顶部工具栏 */
.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 28rpx;
  background: #fff;
  border-bottom: 1rpx solid var(--border);
}
.kb-switch {
  display: flex;
  align-items: center;
}
.kb-label {
  font-size: 28rpx;
  margin-right: 12rpx;
  color: var(--text);
}
.clear-btn {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 消息列表 */
.msg-list {
  flex: 1;
  padding: 24rpx;
}
.msg-row {
  display: flex;
  margin-bottom: 28rpx;
  align-items: flex-start;
}
.msg-right {
  flex-direction: row-reverse;
}
.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--primary);
  color: #fff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.msg-left .avatar {
  background: #fff;
  color: var(--primary);
  border: 2rpx solid var(--primary-light);
}
.bubble-wrap {
  max-width: 76%;
  margin: 0 16rpx;
}
.bubble {
  padding: 20rpx 26rpx;
  border-radius: 20rpx;
  line-height: 1.6;
  word-break: break-all;
}
.bubble-ai {
  background: #fff;
  color: var(--text);
  border-top-left-radius: 4rpx;
}
.bubble-user {
  background: var(--primary);
  color: #fff;
  border-top-right-radius: 4rpx;
}
.bubble-text {
  white-space: pre-wrap;
}

/* 思考中加载动效（三个跳动圆点） */
.thinking {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 0;
}
.dot {
  width: 14rpx;
  height: 14rpx;
  background: #b9c6f5;
  border-radius: 50%;
  animation: bounce 1.2s infinite ease-in-out;
}
.dot:nth-child(2) {
  animation-delay: 0.2s;
}
.dot:nth-child(3) {
  animation-delay: 0.4s;
}
@keyframes bounce {
  0%, 60%, 100% {
    transform: translateY(0);
    opacity: 0.4;
  }
  30% {
    transform: translateY(-12rpx);
    opacity: 1;
  }
}

/* 知识来源 */
.sources {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
}
.sources-title {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-right: 8rpx;
}
.source-tag {
  font-size: 22rpx;
  color: var(--primary);
  background: var(--primary-light);
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  margin: 4rpx 6rpx 4rpx 0;
}

/* 输入区 */
.input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
  border-top: 1rpx solid var(--border);
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}
.input {
  flex: 1;
  height: 72rpx;
  background: var(--bg);
  border-radius: 36rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
}
.send-btn {
  margin-left: 16rpx;
  background: var(--primary);
  color: #fff;
  font-size: 28rpx;
  padding: 0 32rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
}
.send-disabled {
  background: #b9c6f5;
}
