<view class="page">
  <!-- 说明 -->
  <view class="tip card">
    <text class="tip-title">💡 知识库说明</text>
    <text class="tip-text">上传文档后，系统会自动分块、向量化并入库。在对话页开启「知识库」开关，即可基于这些文档问答。目前支持 .txt / .md 文件。</text>
  </view>

  <!-- 上传按钮 -->
  <view class="upload-btn" bindtap="onUpload">
    <text class="upload-icon">＋</text>
    <text>上传文档</text>
  </view>

  <!-- 文档列表 -->
  <view class="doc-list">
    <block wx:if="{{documents.length > 0}}">
      <view class="doc card" wx:for="{{documents}}" wx:key="id">
        <view class="doc-main">
          <view class="doc-name">{{item.name}}</view>
          <view class="doc-meta">
            <text class="meta-tag">📦 {{item.chunkCount}} 块</text>
            <text class="meta-time">{{item.createdAt}}</text>
          </view>
        </view>
        <text class="doc-del" bindtap="onDelete" data-id="{{item.id}}" data-name="{{item.name}}">删除</text>
      </view>
    </block>

    <view wx:elif="{{!loading}}" class="empty">
      <text class="empty-icon">📄</text>
      <text class="empty-text">还没有文档，点击上方上传吧</text>
    </view>
  </view>
</view>
