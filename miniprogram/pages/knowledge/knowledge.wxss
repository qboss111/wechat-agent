.page {
  padding: 24rpx;
}

.tip {
  background: var(--primary-light);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 28rpx;
}
.tip-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary);
  margin-bottom: 12rpx;
}
.tip-text {
  display: block;
  font-size: 24rpx;
  color: #555;
  line-height: 1.6;
}

.upload-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  background: #fff;
  border: 2rpx dashed var(--primary);
  border-radius: 16rpx;
  color: var(--primary);
  font-size: 30rpx;
  margin-bottom: 28rpx;
}
.upload-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

/* 文档卡片 */
.doc {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx;
}
.doc-main {
  flex: 1;
  min-width: 0;
}
.doc-name {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text);
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  margin-bottom: 12rpx;
}
.doc-meta {
  display: flex;
  align-items: center;
}
.meta-tag {
  font-size: 24rpx;
  color: var(--primary);
  background: var(--primary-light);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 16rpx;
}
.meta-time {
  font-size: 22rpx;
  color: var(--text-secondary);
}
.doc-del {
  font-size: 26rpx;
  color: #f56c6c;
  padding: 10rpx 20rpx;
  flex-shrink: 0;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}
.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}
.empty-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}
