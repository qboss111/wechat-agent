.page {
  padding: 24rpx;
}

.section-title {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin: 12rpx 12rpx 16rpx;
}

/* 状态卡片 */
.status-card {
  position: relative;
}
.status-row {
  display: flex;
  align-items: center;
  font-size: 30rpx;
}
.status-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}
.dot-ok {
  background: #67c23a;
}
.dot-err {
  background: #f56c6c;
}
.status-info {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--border);
}
.info-line {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.9;
}
.recheck {
  position: absolute;
  top: 28rpx;
  right: 28rpx;
  font-size: 24rpx;
  color: var(--primary);
}

/* 地址输入 */
.url-input {
  height: 80rpx;
  background: var(--bg);
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  margin-bottom: 12rpx;
}
.hint {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 24rpx;
  line-height: 1.5;
}
.btn-primary {
  margin-top: 8rpx;
}

/* 数据管理 */
.action-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 8rpx;
  font-size: 30rpx;
  border-bottom: 1rpx solid var(--border);
}
.action-row:last-child {
  border-bottom: none;
}
.arrow {
  color: var(--text-secondary);
  font-size: 40rpx;
}
.danger-text {
  color: #f56c6c;
}

.footer {
  text-align: center;
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 60rpx;
  padding-bottom: 40rpx;
}
