.md {
  font-size: 28rpx;
  line-height: 1.7;
  word-break: break-all;
}

/* 段落 */
.md-p {
  margin: 12rpx 0;
  white-space: pre-wrap;
}

/* 标题 */
.md-h1 {
  font-size: 38rpx;
  font-weight: 700;
  margin: 20rpx 0 12rpx;
}
.md-h2 {
  font-size: 34rpx;
  font-weight: 700;
  margin: 18rpx 0 10rpx;
}
.md-h3 {
  font-size: 30rpx;
  font-weight: 600;
  margin: 14rpx 0 8rpx;
}

/* 代码块 */
.md-code-block {
  background: #1e1e2e;
  border-radius: 12rpx;
  margin: 16rpx 0;
  overflow: hidden;
}
.md-code-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 20rpx;
  background: #2a2a3e;
}
.md-code-lang {
  font-size: 22rpx;
  color: #a0a0c0;
}
.md-code-copy {
  font-size: 24rpx;
  color: #8ab4f8;
}
.md-code-text {
  display: block;
  padding: 20rpx;
  font-size: 26rpx;
  color: #e0e0f0;
  white-space: pre;
  overflow-x: auto;
  font-family: 'Consolas', 'Monaco', monospace;
}

/* 引用 */
.md-quote {
  margin: 12rpx 0;
  padding: 12rpx 20rpx;
  border-left: 6rpx solid #b9c6f5;
  background: #f5f6fa;
  color: #555;
  border-radius: 0 8rpx 8rpx 0;
  white-space: pre-wrap;
}

/* 分隔线 */
.md-hr {
  height: 1rpx;
  background: #e0e0e0;
  margin: 20rpx 0;
}

/* 列表 */
.md-list {
  margin: 12rpx 0;
  padding-left: 8rpx;
}
.md-li {
  display: flex;
  align-items: flex-start;
  margin: 6rpx 0;
}
.md-bullet,
.md-num {
  color: #4a6cf7;
  margin-right: 12rpx;
  font-weight: 600;
  flex-shrink: 0;
}
.md-li-text {
  flex: 1;
}
