/* 全局样式 + 主题变量 */
page {
  --primary: #4a6cf7;
  --primary-light: #e8eeff;
  --bg: #f5f6fa;
  --card: #ffffff;
  --text: #1a1a1a;
  --text-secondary: #888888;
  --border: #ececf0;
  background-color: var(--bg);
  color: var(--text);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', 'PingFang SC',
    'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
}

view,
text {
  box-sizing: border-box;
}

/* 通用按钮 */
.btn-primary {
  background: var(--primary);
  color: #fff;
  border-radius: 48rpx;
  padding: 22rpx 0;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
}

.btn-primary[disabled] {
  background: #b9c6f5;
}

/* 卡片 */
.card {
  background: var(--card);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}
