# ===== 智谱 API 配置（双 Key 双端点）=====

# 1) 对话 Key：用 Coding Plan 套餐 Key（GLM-5 编码对话）
ZHIPU_API_KEY=your_coding_plan_api_key_here

# 2) 向量化 Key：用普通按量计费 Key（支持 embedding，新用户通常有免费额度）
#    申请：bigmodel.cn 控制台 → API Keys → 创建（与上面 Coding Key 不同）
#    留空则向量化复用上面的 ZHIPU_API_KEY
ZHIPU_EMBEDDING_API_KEY=your_normal_api_key_here

# ===== 模型配置（改这里即可切换模型，无需改代码）=====
# 对话模型：glm-5 / glm-4.6 / glm-4-flash 等
CHAT_MODEL=glm-5
# 向量化模型：embedding-3（付费，2048维）/ embedding-2（免费，1024维）
EMBEDDING_MODEL=embedding-3

# ===== 接入地址 =====
# 对话（Coding Plan 套餐专用）
CHAT_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
# 向量化（普通按量付费）
EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ===== RAG 参数 =====
# 文本分块大小（字符数）
CHUNK_SIZE=500
# 分块重叠（字符数）
CHUNK_OVERLAP=80
# 检索召回的知识块数量
RAG_TOP_K=5

# ===== 服务配置 =====
PORT=3000
